From 876fd9c895eadd7b5fa78a62c9e8aace101bcfbc Mon Sep 17 00:00:00 2001
From: Glenn Strauss <gstrauss@gluelogic.com>
Date: Fri, 2 Jul 2021 03:03:19 -0400
Subject: [PATCH 1/4] [core] _WIN32 casts to quiet some VS warnings

Upstream-Status: Backport
---
 src/configfile.c | 2 +-
 src/lemon.c      | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/src/configfile.c b/src/configfile.c
index d41158a5..b8be6624 100644
--- a/src/configfile.c
+++ b/src/configfile.c
@@ -2401,7 +2401,7 @@ int config_remoteip_normalize(buffer * const b, buffer * const tb) {
     if (NULL != slash) {
         char *nptr;
         nm_bits = strtoul(slash + 1, &nptr, 10);
-        if (*nptr || 0 == nm_bits || nm_bits > (NULL != colon ? 128 : 32)) {
+        if (*nptr || 0 == nm_bits || nm_bits > (NULL != colon ? 128u : 32u)) {
             /*(also rejects (slash+1 == nptr) which results in nm_bits = 0)*/
             return -1;
         }
diff --git a/src/lemon.c b/src/lemon.c
index 907af878..4b5c87ac 100644
--- a/src/lemon.c
+++ b/src/lemon.c
@@ -6,6 +6,10 @@
 **
 ** The author of this program disclaims copyright.
 */
+#ifdef _MSC_VER
+#define _CRT_SECURE_NO_WARNINGS
+#endif
+
 #include <stdio.h>
 #include <stdarg.h>
 #include <string.h>
